# LLM Configuration
# Set to "proxy" on Railway/production to route through server-side API
NEXT_PUBLIC_LLM_MODE=direct

# Ollama endpoint (Cloudflare tunnel URL for production)
# Only used server-side when LLM_MODE=proxy
LLM_OLLAMA_URL=http://localhost:11434

# OpenRouter fallback (used when Ollama is unreachable)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Ollama connection timeout in ms (default: 5000)
LLM_OLLAMA_TIMEOUT=5000

# Notion Leaderboard (Hall of Fame)
# Create integration at https://www.notion.so/my-integrations
NOTION_API_KEY=
NOTION_DATABASE_ID=
